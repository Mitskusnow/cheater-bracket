def _core_logic(my_pos, board, grid_dim, players):
    DIRS = {"UP": (0, -1), "DOWN": (0, 1), "LEFT": (-1, 0), "RIGHT": (1, 0)}
    
    def is_safe(p):
        return 0 <= p[0] < grid_dim and 0 <= p[1] < grid_dim and p not in board

    best_dir = "UP"
    max_score = -float('inf')

    # Calculate Voronoi-based territorial control
    for d_name, (dx, dy) in DIRS.items():
        target = (my_pos[0] + dx, my_pos[1] + dy)
        if not is_safe(target):
            continue

        # Simulate move
        sim_board = board.copy()
        sim_board[target] = "OCCUPIED"
        
        # 1. Self-Mobility (Flood Fill)
        q, seen = deque([target]), {target}
        while q:
            curr = q.popleft()
            for vx, vy in DIRS.values():
                step = (curr[0]+vx, curr[1]+vy)
                if 0 <= step[0] < grid_dim and 0 <= step[1] < grid_dim and step not in sim_board and step not in seen:
                    seen.add(step)
                    q.append(step)
        
        # 2. Opponent Pressure
        # We find the nearest alive opponent and check if we are restricting them
        opp_space = 0
        alive_opps = [p for p in players if p['alive'] and p['pos'] != my_pos]
        for op in alive_opps:
            op_q, op_seen = deque([op['pos']]), {op['pos']}
            while op_q:
                curr = op_q.popleft()
                for vx, vy in DIRS.values():
                    step = (curr[0]+vx, curr[1]+vy)
                    if 0 <= step[0] < grid_dim and 0 <= step[1] < grid_dim and step not in sim_board and step not in op_seen:
                        op_seen.add(step)
                        op_q.append(step)
            opp_space += len(op_seen)

        # 3. Final Heuristic
        # We prioritize our space (1x) and destroying opponent space (1.5x)
        score = len(seen) - (opp_space * 1.5)
        
        # Bonus for staying away from walls/center depending on game phase
        dist_to_mid = abs(target[0] - grid_dim//2) + abs(target[1] - grid_dim//2)
        score -= dist_to_mid * 0.2

        if score > max_score:
            max_score, best_dir = score, d_name
            
    return best_dir

